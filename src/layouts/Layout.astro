---
import "../styles/global.css";

interface Props {
  title?: string;
}
const { title = "Japanese Memorama" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Aprende vocabulario japonés de Minna no Nihongo"
    />
    <title>{title} — Japanese Memorama</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <header
      class="border-b border-slate-800 bg-slate-900/80 backdrop-blur sticky top-0 z-50"
    >
      <div
        class="max-w-4xl mx-auto px-4 h-14 flex items-center justify-between"
      >
        <a
          href="/"
          class="flex items-center gap-2 font-bold text-lg text-violet-400 hover:text-violet-300 transition-colors"
        >
          <span>🗾</span>
          <span>Japanese Memorama</span>
        </a>
        <nav class="flex items-center gap-2 text-sm text-slate-400">
          <a href="/" class="hover:text-slate-200 transition-colors">Inicio</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="text-center text-slate-500 text-xs py-2 mt-2 space-y-2">
      <p>
        Vocabulario de <strong class="text-slate-400">Minna no Nihongo</strong> ·
        Hecho con ❤️ para aprender japonés
      </p>
      <p class="text-slate-500">
        Senior Software Engineer · Gerardo Manuel Chavez Larios
      </p>
      <p class="flex items-center justify-center gap-4">
        <a
          href="https://github.com/GerryLarios"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-slate-300 transition-colors"
        >
          GitHub
        </a>
        <span class="text-slate-700">·</span>
        <a
          href="https://linkedin.com/in/gerardo-larios"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-slate-300 transition-colors"
        >
          LinkedIn
        </a>
      </p>
    </footer>
  </body>
</html>
